# =========================
outputs/
output/
runs/
models/
checkpoints/

*.joblib
*.pkl
*.pickle
*.pth
*.pt
*.ckpt
*.onnx

# =========================
# Temporary files
# =========================
temp/
tmp/
*.tmp
*.bak
*.swp

# =========================
# Logs
