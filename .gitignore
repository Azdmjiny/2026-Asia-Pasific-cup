*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/
.apmcm-torch/
*.egg-info/

# =========================
# Jupyter Notebook
# =========================
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# =========================
# VS Code / IDE
# =========================
.vscode/
.idea/

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db
desktop.ini

# =========================
